<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FormaStream.App"
             xmlns:local="using:FormaStream"
             xmlns:converters="clr-namespace:FormaStream.Infrastructure.Converters"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />

        <StyleInclude Source="avares://FormaStream/Shell/Styles/ConfirmationStyles.axaml" />
        <StyleInclude Source="avares://FormaStream/Shell/Styles/TreeViewStyles.axaml" />
        <StyleInclude Source="avares://FormaStream/Shell/Styles/ToggleButtonStyles.axaml" />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <converters:StringNotEmptyToBoolConverter x:Key="StringNotEmptyToBoolConverter" />

            <SolidColorBrush x:Key="PrimaryGreen" Color="#4CAF50" /> <!-- Зеленый -->
            <SolidColorBrush x:Key="SurfaceBrush" Color="#F5F5F5" /> <!-- Светло-серый -->
        </ResourceDictionary>
    </Application.Resources>
</Application>