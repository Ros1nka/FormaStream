<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:FormaStream.Shell.ViewModels"
             xmlns:treeNodes="clr-namespace:FormaStream.Shell.ViewModels.TreeNodes"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FormaStream.Shell.View.Archive"
             x:DataType="viewModels:ArchiveViewModel">


    <Design.DataContext>
        <viewModels:ArchiveViewModel />
    </Design.DataContext>

    <Grid Background="LightSlateGray">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="150" MaxWidth="500" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="200" MinWidth="100" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" MinWidth="300" />
        </Grid.ColumnDefinitions>

        <!-- Кнопки управления -->
        <Grid Grid.Column="0" Margin="20" RowDefinitions="100, 100, 100, 100, 100, *" ColumnDefinitions="100, *">
            <Button Grid.Row="0" Grid.Column="0" Width="90" Height="90" Margin="5"
                    Command="{Binding OpenSourceFolderCommand}"
                    IsEnabled="true">
                <TextBlock Text="Выбрать папку" TextWrapping="Wrap"> </TextBlock>
            </Button>
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Text="{Binding SourceFolder}"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"
                       ToolTip.Tip="{Binding SourceFolder}" />

            <Button Grid.Row="1" Grid.Column="0" Width="90" Height="90" Margin="5"
                    Command="{Binding ShowFolderOrFilesCommand}">
                <TextBlock Text="Открыть в проводнике" TextWrapping="Wrap"> </TextBlock>
            </Button>

            <Button Grid.Row="2" Grid.Column="0" Width="90" Height="90" Margin="5"
                    Command="{Binding ArchivingCommand}">
                <!-- IsEnabled= "{Binding IsArchivingButtonEnabled}" -->
                <TextBlock Text="Архивирование" TextWrapping="Wrap"> </TextBlock>
            </Button>

            <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                      Content="Архивировать в Zip"
                      IsChecked="{Binding IsYesArchiveDirection}"
                      Margin="10,5"
                      FontFamily="JetBrains Mono"
                      FontSize="12"
                      VerticalAlignment="Center" />

            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2">
                <TextBlock Text="Архивировать в папку заказчика"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
                <Border BorderThickness="2"
                        BorderBrush="Blue"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding IsFullPath}"
                                  Margin="10,5"
                                  FontFamily="JetBrains Mono"
                                  FontSize="12"
                                  VerticalAlignment="Center" />
                        <TextBox Margin="0,30"
                                 Text="{Binding ClientDir}"
                                 TextWrapping="Wrap"
                                 IsEnabled="{Binding IsFullPath}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Сплиттер -->
        <GridSplitter Grid.Column="1" Width="6"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="False" />

        <!-- info -->
        <Grid Grid.Column="2" Margin="10">
            <Border Grid.Column="0"
                    CornerRadius="12"
                    Background="BlanchedAlmond"
                    Padding="10"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">

                <SelectableTextBlock Text="{Binding ItemInfoText}"
                           FontSize="10"
                           FontFamily="Consolas"
                           TextAlignment="Left"
                           TextWrapping="Wrap"
                           Foreground="Black"
                           FontWeight="DemiBold"/>
            </Border>
        </Grid>

        <!-- Сплиттер -->
        <GridSplitter Grid.Column="3" Width="6"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="False" />

        <Grid Grid.Column="4" RowDefinitions="40, *">

            <!-- Панель кнопок управления деревом -->
            <StackPanel Grid.Row="0" Margin="10,0,10,10" 
                        Orientation="Horizontal" Spacing="8">
                
                <Button Command="{Binding CollapseAllCommand}"
                        Width="80" FontSize="10" CornerRadius="0,0,8,8"
                        ToolTip.Tip="Свернуть всё" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="📁" />
                        <TextBlock Text="Свернуть" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding ExpandVariantsOnlyCommand}"
                        Width="80" FontSize="10" CornerRadius="0,0,8,8"
                        ToolTip.Tip="Раскрыть виды" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="🎯" />
                        <TextBlock Text="Виды" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding ExpandAllCommand}" 
                        Width="80" FontSize="10" CornerRadius="0,0,8,8"
                        Margin="0" ToolTip.Tip="Раскрыть всё" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="📂" />
                        <TextBlock Text="Файлы" />
                    </StackPanel>
                </Button>
            </StackPanel>


            <!-- TreeView с файлами -->
            <TreeView Grid.Row="1" Margin="10, 24"
                      ItemsSource="{Binding TreeNodes}"
                      SelectedItem="{Binding SelectedNode}">

                <TreeView.DataTemplates>
                    <TreeDataTemplate DataType="{x:Type treeNodes:TreeNode}"
                                      ItemsSource="{Binding Children}">
                        <StackPanel x:DataType="treeNodes:TreeNode" Orientation="Horizontal" Spacing="8">
                            <!-- Добавьте Mode=OneWay если нужно -->
                            <TextBlock Text="{Binding IconSymbol}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.DataTemplates>
            </TreeView>
        </Grid>
    </Grid>
</UserControl>