<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:FormaStream.Shell.ViewModels"
             xmlns:treeNodes="clr-namespace:FormaStream.Shell.ViewModels.TreeNodes"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FormaStream.Shell.View.Archive"
             x:DataType="viewModels:ArchiveViewModel">


    <Design.DataContext>
        <viewModels:ArchiveViewModel />
    </Design.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="150" MaxWidth="500" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="200" MinWidth="100" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" MinWidth="300" />
        </Grid.ColumnDefinitions>

        <!-- Кнопки управления -->
        <Grid Grid.Column="0" Margin="20" RowDefinitions="100, 100, 100, 100, 100, *" ColumnDefinitions="100, *">
            <Button Grid.Row="0" Grid.Column="0" Width="100" Height="100"
                    Command="{Binding OpenSourceFolderCommand}"
                    IsEnabled="true">
                <TextBlock Text="Выбрать папку" TextWrapping="Wrap"> </TextBlock>
            </Button>
            <Button Grid.Row="1" Grid.Column="0" Width="100" Height="100"
                    Command="{Binding ShowFolderOrFilesCommand}"
                    IsEnabled= "{Binding IsOpenFolderButtonEnabled}">
                <TextBlock Text="Открыть в проводнике" TextWrapping="Wrap"> </TextBlock>
            </Button>
            <Button Grid.Row="2" Grid.Column="0" Width="100" Height="100"
                    Command="{Binding ArchivingCommand}">
                    <!-- IsEnabled= "{Binding IsArchivingButtonEnabled}" -->
                <TextBlock Text="Архивирование" TextWrapping="Wrap"> </TextBlock>
            </Button>
            <CheckBox Grid.Row="3" Grid.Column="0" 
                      Content="Архивировать в Zip" 
                      IsChecked="{Binding IsYesArchiveDirection}" 
                      Margin="10,5" 
                      FontFamily="JetBrains Mono" 
                      FontSize="12"
                      VerticalAlignment="Center"/>
            <CheckBox Grid.Row="4" Grid.Column="0" 
                      Content="Архивировать в папку заказчика" 
                      IsChecked="{Binding IsFullPath}" 
                      Margin="10,5" 
                      FontFamily="JetBrains Mono" 
                      FontSize="12"
                      VerticalAlignment="Center"/>
        </Grid>

        <!-- Сплиттер -->
        <GridSplitter Grid.Column="1" Width="6"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="False" />

        <!-- info -->
        <Grid Grid.Column="2" Margin="10">
            <Border Grid.Column="0"
                    CornerRadius="12"
                    Background="BlanchedAlmond"
                    Padding="10"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">

                <TextBlock Text="{Binding ItemInfoText}"
                           FontSize="10"
                           FontFamily="Consolas"
                           TextAlignment="Left"
                           TextWrapping="Wrap"
                           Foreground="Black"
                           FontWeight="DemiBold"/>
            </Border>
        </Grid>

        <!-- Сплиттер -->
        <GridSplitter Grid.Column="3" Width="6"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="False" />

        <Grid Grid.Column="4" Grid.RowDefinitions="50, *">
            
            <!-- Панель кнопок управления деревом -->
            <StackPanel Grid.Row="0" Margin="10,10,10,10" 
                        Orientation="Horizontal" Spacing="8">
    
                <Button Command="{Binding ExpandAllCommand}" 
                        Width="80" Height="50" FontSize="10"
                        ToolTip.Tip="Раскрыть всё">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="📂"/>
                        <TextBlock Text="Файлы"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding ExpandVariantsOnlyCommand}" 
                        Width="80" Height="50" FontSize="10"
                        ToolTip.Tip="Раскрыть виды">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="🎯"/>
                        <TextBlock Text="Виды"/>
                    </StackPanel>
                </Button>
                
                <Button Command="{Binding CollapseAllCommand}" 
                        Width="80" Height="50" FontSize="10"
                        ToolTip.Tip="Свернуть всё">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="📁"/>
                        <TextBlock Text="Свернуть"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            
            <!-- TreeView с файлами -->
            <TreeView Grid.Row="1" Margin="10, 24"
                      ItemsSource="{Binding TreeNodes}"
                      SelectedItem="{Binding SelectedNode}">
                
                <TreeView.DataTemplates>
                    <TreeDataTemplate DataType="{x:Type treeNodes:TreeNode}"
                                      ItemsSource="{Binding Children}">
                        <StackPanel x:DataType="treeNodes:TreeNode" Orientation="Horizontal" Spacing="8">
                            <!-- Добавьте Mode=OneWay если нужно -->
                            <TextBlock Text="{Binding IconSymbol}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.DataTemplates>
            </TreeView>
        </Grid>
    </Grid>
</UserControl>