<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:treeNodes="clr-namespace:FormaStream.Shell.ViewModels.TreeNodes"
             xmlns:viewModels="clr-namespace:FormaStream.Shell.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FormaStream.Shell.Views.FolderBrowserView"
             x:DataType="viewModels:FolderBrowserViewModel">


    <Design.DataContext>
        <viewModels:FolderBrowserViewModel />
    </Design.DataContext>
    
    
    <!-- TreeView с файлами -->
    <TreeView Margin="10, 24"
              ItemsSource="{Binding TreeNodes}"
              SelectedItem="{Binding SelectedNode}">

        <TreeView.DataTemplates>

            <!-- OrderNode -->
            <TreeDataTemplate DataType="{x:Type treeNodes:OrderNode}"
                              ItemsSource="{Binding Children}">
                <!-- Orientation="Horizontal" Spacing="8 -->
                <Grid ColumnDefinitions="Auto, Auto, Auto, Auto, Auto, *, Auto">

                    <TextBlock Grid.Column="0" Text="{Binding IconSymbol}" VerticalAlignment="Center" />

                    <TextBox Grid.Column="1"
                             Text="{Binding OrderNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center" MaxWidth="200" BorderThickness="0"
                             KeyDown="EditableTextBox_KeyDown" />

                    <TextBox Grid.Column="2"
                             Text="{Binding ClientName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Background="{Binding ClientNameBackground}"
                             VerticalAlignment="Center" MaxWidth="200"
                             KeyDown="EditableTextBox_KeyDown"
                             BorderThickness="0">
                        <TextBox.Styles>
                            <Style Selector="TextBox">
                                <Setter Property="Transitions">
                                    <Transitions>
                                        <BrushTransition Property="Background" Duration="0:0:1.12" />
                                    </Transitions>
                                </Setter>
                            </Style>
                        </TextBox.Styles>
                    </TextBox>

                    <TextBox Grid.Column="3" VerticalAlignment="Center" MaxWidth="200" BorderThickness="0"
                             Text="{Binding ClientNameTranslit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="EditableTextBox_KeyDown" />

                    <Button Grid.Column="4" Padding="4,0" Margin="2,0"
                            Command="{Binding ConfirmChanges}"
                            IsEnabled="{Binding IsModified}"
                            IsVisible="{Binding IsModified}"
                            ToolTip.Tip="Подтвердить (Enter)">
                        <Image Source="/Assets/Confirm.png"
                               Margin="0" Height="18" Stretch="Uniform" />
                    </Button>

                    <Button Grid.Column="5" Padding="4,0" Margin="2,0"
                            Command="{Binding CancelChanges}"
                            IsEnabled="{Binding IsModified}"
                            IsVisible="{Binding IsModified}"
                            ToolTip.Tip="Отменить (Esc)">
                        <Image Source="/Assets/RedCross.png"
                               Margin="0" Height="18" Stretch="Uniform" />
                    </Button>

                    <Border Grid.Column="6" Width="200">

                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" Height="12"
                                   HorizontalAlignment="Right" />
                    </Border>

                </Grid>
            </TreeDataTemplate>

            <!-- VariantNode-->
            <TreeDataTemplate DataType="{x:Type treeNodes:VariantNode}"
                              ItemsSource="{Binding Children}">

                <StackPanel Orientation="Horizontal" Spacing="8">

                    <TextBlock Text="{Binding IconSymbol}" VerticalAlignment="Center" />

                    <TextBox
                        Text="{Binding VariantNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        VerticalAlignment="Center" Height="18" MaxWidth="200" BorderThickness="0"
                        KeyDown="EditableTextBox_KeyDown" />

                    <Button Command="{Binding ConfirmChanges}"
                            IsEnabled="{Binding IsModified}"
                            IsVisible="{Binding IsModified}"
                            Padding="4,0" Margin="2,0"
                            ToolTip.Tip="Подтвердить (Enter)">
                        <Image Source="/Assets/Confirm.png"
                               Margin="0" Height="18" Stretch="Uniform" />
                    </Button>

                    <Button Command="{Binding CancelChanges}"
                            IsEnabled="{Binding IsModified}"
                            IsVisible="{Binding IsModified}"
                            Padding="4,0" Margin="2,0"
                            ToolTip.Tip="Отменить (Esc)">
                        <Image Source="/Assets/RedCross.png"
                               Margin="0" Height="18" Stretch="Uniform" />
                    </Button>

                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" Height="18" />
                </StackPanel>
            </TreeDataTemplate>

            <!--FileNode -->
            <TreeDataTemplate DataType="{x:Type treeNodes:FileNode}"
                              ItemsSource="{Binding Children}">
                <Border Background="Transparent"
                        PointerPressed="FileNode_Tapped"
                        x:DataType="treeNodes:FileNode"
                        Padding="2">
                    <StackPanel Orientation="Horizontal" Spacing="8">

                        <TextBlock Text="{Binding IconSymbol}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </TreeDataTemplate>

        </TreeView.DataTemplates>
    </TreeView>
</UserControl>