<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:treeNodes="clr-namespace:FormaStream.Shell.ViewModels.TreeNodes;assembly=FormaStream">
    
    <!-- ========== БАЗОВЫЙ ШАБЛОН ========== -->
    <Style Selector="TreeViewItem" x:DataType="treeNodes:TreeNode">
        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
        <!-- Явно задаём начальное состояние: все узлы свёрнуты -->
        <!-- <Setter Property="IsExpanded" Value="False" /> -->
        <Setter Property="Margin" Value="0,0, 0, 5" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="8"/>
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontWeight" Value="SemiBold"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <!-- row: родители - дети -->
                    <Grid RowDefinitions="Auto, *">
                        <Grid x:Name="PART_HeaderGrid"
                              Grid.Row="0"
                              ColumnDefinitions="16,*,Auto"
                              Margin="0"
                              Background="Transparent">

                            <ToggleButton x:Name="PART_ExpandCollapseToggle"
                                          Grid.Column="0"
                                          Width="16" Height="16"
                                          Margin="0" Padding="4"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{TemplateBinding IsExpanded, Mode=TwoWay}" />

                            <ContentPresenter x:Name="PART_HeaderPresenter"
                                              Grid.Column="1"
                                              Padding="4,2" Margin="0"
                                              HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Stretch"
                                              Content="{TemplateBinding Header}"
                                              ContentTemplate="{TemplateBinding HeaderTemplate}" />
                        </Grid>

                        <!-- дети скрываются/показываются по IsExpanded -->
                        <ItemsPresenter x:Name="PART_ItemsPresenter"
                                        Grid.Row="1"
                                        ItemsPanel="{TemplateBinding ItemsPanel}"
                                        Margin="48,8,0,0"
                                        IsVisible="{TemplateBinding IsExpanded}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 🟢 СБРОС ОТСТУПА ДЛЯ КОНЕЧНЫХ УЗЛОВ (листьев) -->
    <!-- Селектор [ItemCount=0] более специфичен, поэтому переопределяет Margin="0,3" выше -->
    <Style Selector="TreeViewItem[ItemCount=0]">
        <Setter Property="Margin" Value="0" />
    </Style>

    <!-- ========== ВЫДЕЛЕНИЕ / НАВЕДЕНИЕ ========== -->
    <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
        <Setter Property="Background" Value="LightSteelBlue" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
        <Setter Property="Background" Value="#DBEAFE" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- ========== ИКОНКА РАСКРЫТИЯ (полностью контролируемая) ========== -->
    <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseToggle">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <!-- Минимальный шаблон: только ваш контент. Никаких стандартных бордеров, фонов или VisualState -->
                <ControlTemplate TargetType="ToggleButton">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"
                                      Padding="0" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========== КАСТОМНЫЙ КОНТЕНТ (Border + PathIcon) ========== -->
    <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseToggle">
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Border x:Name="IconBorder"
                            Background="Transparent"
                            Width="16" Height="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <PathIcon x:Name="ArrowIcon"
                                  Data="M7 5l5 5-5 5"
                                  Width="12" Height="10"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Foreground="Gray" />
                    </Border>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Переопределяем для узлов без детей -->
    <Style Selector="TreeViewItem[ItemCount=0] /template/ ToggleButton#PART_ExpandCollapseToggle">
        <Setter Property="IsVisible" Value="False" />
    </Style>

    <!-- Принудительно сбрасываем фон во всех состояниях -->
    <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseToggle Border">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseToggle:pointerover Border">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseToggle:pressed Border">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="TreeViewItem:selected /template/ ToggleButton#PART_ExpandCollapseToggle Border">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Поворот при раскрытии + смена цвета иконки -->
    <Style Selector="TreeViewItem[IsExpanded=True] /template/ ToggleButton#PART_ExpandCollapseToggle PathIcon">
        <Setter Property="RenderTransform">
            <Setter.Value>
                <RotateTransform Angle="90" CenterX="1" CenterY="1" />
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="White" />
    </Style>
    
    <!-- Изменение фона при раскрытии -->
    <!-- <Style -->
    <!--     Selector="TreeViewItem[IsExpanded=True] /template/ ToggleButton#PART_ExpandCollapseToggle /template/ ContentPresenter#PART_ContentPresenter"> -->
    <!--     <Setter Property="Background" Value="Transparent" /> -->
    <!-- </Style> -->

</Styles>